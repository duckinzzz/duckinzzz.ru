# Django
SECRET_KEY=generate-a-random-secret-key
DEBUG=True

# Database — DATABASE_URL format (only needed when DEBUG=False)
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@host:5432/dbname
# When DEBUG=True and DATABASE_URL is unset, SQLite is used automatically.

# Clash Royale API token (get yours at https://developer.clashroyale.com)
CR_API_TOKEN=your-cr-api-token

# Auth token for botstats API — external bots send this in POST body
BOTSTATS_API_TOKEN=generate-a-random-token

# Gunicorn (optional, defaults to 3)
# GUNICORN_WORKERS=3

# Celery broker (optional, default: redis://redis:6379/0)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Allowed hosts (optional, comma-separated)
# ALLOWED_HOSTS=duckinzzz.ru,www.duckinzzz.ru,127.0.0.1,localhost
